#!/usr/bin/env bash
set -euo pipefail

# AIRIS MCP Gateway - Thin CLI Wrapper
# Just pulls latest and runs docker compose

DIR="${AIRIS_MCP_DIR:-$HOME/.local/share/airis-mcp-gateway}"
REGISTRY_DIR="${AIRIS_REGISTRY_DIR:-$HOME/.airis/mcp}"
REGISTRY_PATH="$REGISTRY_DIR/registry.json"
BACKUP_DIR="$REGISTRY_DIR/backups"
CODEX_CONFIG_PATH="${CODEX_CONFIG_PATH:-$HOME/.codex/config.toml}"
CLAUDE_CODE_DIR="${CLAUDE_CODE_DIR:-$HOME/.claude}"
GEMINI_CONFIG_DIR="${GEMINI_CONFIG_DIR:-$HOME/.gemini}"
CLAUDE_DESKTOP_CONFIG_PATH="${CLAUDE_DESKTOP_CONFIG_PATH:-$HOME/Library/Application Support/Claude/claude_desktop_config.json}"
BASE_URL="https://raw.githubusercontent.com/agiletec-inc/airis-mcp-gateway/${AIRIS_VERSION:-latest}"
GATEWAY_HTTP_URL="${AIRIS_GATEWAY_HTTP_URL:-http://localhost:9400/mcp}"
GATEWAY_SSE_URL="${AIRIS_GATEWAY_SSE_URL:-http://localhost:9400/sse}"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

ensure_registry() {
    mkdir -p "$REGISTRY_DIR" "$BACKUP_DIR"
    if [ ! -f "$REGISTRY_PATH" ]; then
        python3 - "$REGISTRY_PATH" "$GATEWAY_HTTP_URL" "$GATEWAY_SSE_URL" "$CODEX_CONFIG_PATH" "$CLAUDE_DESKTOP_CONFIG_PATH" <<'PY'
import json
import os
import sys

registry_path, gateway_http, gateway_sse, codex_path, claude_path = sys.argv[1:]
registry = {
    "version": 1,
    "gateway": {
        "streamableHttpEndpoint": gateway_http,
        "sseEndpoint": gateway_sse,
        "managed": True,
    },
    "clients": {
        "codex": {
            "managed": True,
            "configPath": codex_path,
            "installed": os.path.exists(codex_path),
            "lastSyncedAt": None,
        },
        "claude_desktop": {
            "managed": False,
            "configPath": claude_path,
            "installed": os.path.exists(os.path.expanduser(claude_path)),
            "lastSyncedAt": None,
        },
    },
    "policy": {
        "repoLocalMcpJson": "forbidden",
        "backupBeforeDelete": True,
    },
    "servers": {},
    "imports": {},
}
with open(registry_path, "w", encoding="utf-8") as f:
    json.dump(registry, f, indent=2)
PY
    fi
}

scan_repo_mcp_json() {
    local scan_root="${1:-$PWD}"
    python3 - "$scan_root" "$REGISTRY_DIR" <<'PY'
import os
import sys

scan_root = os.path.abspath(os.path.expanduser(sys.argv[1]))
registry_dir = os.path.abspath(os.path.expanduser(sys.argv[2]))
skip_dirs = {
    ".git", ".hg", ".svn", "node_modules", ".venv", "venv",
    "dist", "build", ".next", "target", "__pycache__",
}

for root, dirs, files in os.walk(scan_root):
    dirs[:] = [
        d for d in dirs
        if d not in skip_dirs and not os.path.abspath(os.path.join(root, d)).startswith(registry_dir)
    ]
    if "mcp.json" in files:
        print(os.path.join(root, "mcp.json"))
PY
}

sync_codex_registration() {
    if ! command -v codex >/dev/null 2>&1; then
        return 1
    fi

    codex mcp remove airis-mcp-gateway >/dev/null 2>&1 || true
    codex mcp add airis-mcp-gateway --url "$GATEWAY_HTTP_URL" >/dev/null 2>&1
}

ensure_files() {
    mkdir -p "$DIR"
    if [ ! -f "$DIR/docker-compose.yml" ]; then
        log_info "Downloading docker-compose.yml..."
        curl -fsSL "$BASE_URL/docker-compose.dist.yml" -o "$DIR/docker-compose.yml"
    fi
    if [ ! -f "$DIR/mcp-config.json" ]; then
        log_info "Downloading default config..."
        curl -fsSL "$BASE_URL/mcp-config.json.example" -o "$DIR/mcp-config.json"
    fi
    ensure_bootstrap_support
}

ensure_bootstrap_support() {
    mkdir -p \
        "$DIR/scripts" \
        "$DIR/config/bootstrap/assets/common" \
        "$DIR/config/bootstrap/assets/claude/commands"

    if [ ! -f "$DIR/scripts/airis_bootstrap.py" ]; then
        curl -fsSL "$BASE_URL/scripts/airis_bootstrap.py" -o "$DIR/scripts/airis_bootstrap.py"
    fi
    if [ ! -f "$DIR/config/bootstrap/assets-manifest.json" ]; then
        curl -fsSL "$BASE_URL/config/bootstrap/assets-manifest.json" -o "$DIR/config/bootstrap/assets-manifest.json"
    fi
    if [ ! -f "$DIR/config/bootstrap/assets/common/AIRIS-PLAYBOOK.md" ]; then
        curl -fsSL "$BASE_URL/config/bootstrap/assets/common/AIRIS-PLAYBOOK.md" -o "$DIR/config/bootstrap/assets/common/AIRIS-PLAYBOOK.md"
    fi
    if [ ! -f "$DIR/config/bootstrap/assets/claude/commands/airis-research-first.md" ]; then
        curl -fsSL "$BASE_URL/config/bootstrap/assets/claude/commands/airis-research-first.md" -o "$DIR/config/bootstrap/assets/claude/commands/airis-research-first.md"
    fi
    if [ ! -f "$DIR/config/bootstrap/assets/claude/commands/airis-capability-router.md" ]; then
        curl -fsSL "$BASE_URL/config/bootstrap/assets/claude/commands/airis-capability-router.md" -o "$DIR/config/bootstrap/assets/claude/commands/airis-capability-router.md"
    fi
}

cmd_up() {
    ensure_files
    log_info "Starting AIRIS MCP Gateway..."
    cd "$DIR"
    docker compose pull -q 2>/dev/null || true
    docker compose up -d "$@"
    log_info "Gateway started!"
    echo ""
    echo "  API:     http://localhost:9400"
    echo "  Gateway: http://localhost:9390"
    echo ""
    echo "Register with Claude Code:"
    echo "  claude mcp add --scope user --transport sse airis-mcp-gateway http://localhost:9400/sse"
}

cmd_down() {
    if [ -d "$DIR" ]; then
        cd "$DIR"
        docker compose down "$@"
        log_info "Gateway stopped."
    else
        log_warn "Gateway not installed. Run 'airis-gateway up' first."
    fi
}

cmd_logs() {
    if [ -d "$DIR" ]; then
        cd "$DIR"
        docker compose logs "$@"
    else
        log_error "Gateway not installed."
        exit 1
    fi
}

cmd_status() {
    if [ -d "$DIR" ]; then
        cd "$DIR"
        docker compose ps
    else
        log_warn "Gateway not installed."
    fi
    echo ""
    echo "Config: $DIR/mcp-config.json"
    echo "Repo:   $DIR"
}

cmd_restart() {
    cmd_down
    cmd_up "$@"
}

cmd_config() {
    echo "$DIR/mcp-config.json"
    if [ -f "$DIR/mcp-config.json" ]; then
        ${EDITOR:-vim} "$DIR/mcp-config.json"
    else
        log_error "Config not found. Run 'airis-gateway up' first."
        exit 1
    fi
}

cmd_servers() {
    if [ ! -f "$DIR/mcp-config.json" ]; then
        log_error "Config not found. Run 'airis-gateway up' first."
        exit 1
    fi

    echo "MCP Servers ($DIR/mcp-config.json):"
    echo ""

    # Parse JSON and list servers with status
    python3 -c "
import json
import sys

try:
    with open('$DIR/mcp-config.json') as f:
        config = json.load(f)

    servers = config.get('mcpServers', {})
    enabled = []
    disabled = []

    for name, conf in servers.items():
        if name.startswith('__disabled_'):
            disabled.append(name.replace('__disabled_', ''))
        elif conf.get('enabled', True):
            enabled.append(name)
        else:
            disabled.append(name)

    print('  Enabled:')
    for s in sorted(enabled):
        print(f'    - {s}')

    if disabled:
        print('')
        print('  Disabled:')
        for s in sorted(disabled):
            print(f'    - {s}')
except Exception as e:
    print(f'Error: {e}', file=sys.stderr)
    sys.exit(1)
"
}

cmd_enable() {
    local server="$1"
    if [ -z "$server" ]; then
        log_error "Usage: airis-gateway enable <server_name>"
        exit 1
    fi

    if [ ! -f "$DIR/mcp-config.json" ]; then
        log_error "Config not found. Run 'airis-gateway up' first."
        exit 1
    fi

    python3 -c "
import json
import sys

server = '$server'
config_path = '$DIR/mcp-config.json'

with open(config_path) as f:
    config = json.load(f)

servers = config.get('mcpServers', {})

# Check if server exists as disabled
disabled_key = f'__disabled_{server}'
if disabled_key in servers:
    servers[server] = servers.pop(disabled_key)
    servers[server]['enabled'] = True
    with open(config_path, 'w') as f:
        json.dump(config, f, indent=2)
    print(f'Enabled: {server}')
elif server in servers:
    servers[server]['enabled'] = True
    with open(config_path, 'w') as f:
        json.dump(config, f, indent=2)
    print(f'Enabled: {server}')
else:
    print(f'Server not found: {server}', file=sys.stderr)
    print('Available servers:', file=sys.stderr)
    for name in servers:
        clean_name = name.replace('__disabled_', '')
        print(f'  - {clean_name}', file=sys.stderr)
    sys.exit(1)
"
    log_info "Restart gateway to apply: airis-gateway restart"
}

cmd_disable() {
    local server="$1"
    if [ -z "$server" ]; then
        log_error "Usage: airis-gateway disable <server_name>"
        exit 1
    fi

    if [ ! -f "$DIR/mcp-config.json" ]; then
        log_error "Config not found. Run 'airis-gateway up' first."
        exit 1
    fi

    python3 -c "
import json
import sys

server = '$server'
config_path = '$DIR/mcp-config.json'

with open(config_path) as f:
    config = json.load(f)

servers = config.get('mcpServers', {})

if server in servers:
    servers[server]['enabled'] = False
    with open(config_path, 'w') as f:
        json.dump(config, f, indent=2)
    print(f'Disabled: {server}')
else:
    print(f'Server not found: {server}', file=sys.stderr)
    sys.exit(1)
"
    log_info "Restart gateway to apply: airis-gateway restart"
}

cmd_init() {
    ensure_bootstrap_support
    local scan_root="$PWD"
    local apply=false
    while [ $# -gt 0 ]; do
        case "$1" in
            --apply) apply=true ;;
            *) scan_root="$1" ;;
        esac
        shift
    done

    local args=(
        init
        --scan-root "$scan_root"
        --registry-path "$REGISTRY_PATH"
        --registry-dir "$REGISTRY_DIR"
        --backup-dir "$BACKUP_DIR"
        --codex-config-path "$CODEX_CONFIG_PATH"
        --claude-desktop-config-path "$CLAUDE_DESKTOP_CONFIG_PATH"
        --claude-code-dir "$CLAUDE_CODE_DIR"
        --gemini-dir "$GEMINI_CONFIG_DIR"
        --gateway-http-url "$GATEWAY_HTTP_URL"
        --gateway-sse-url "$GATEWAY_SSE_URL"
    )
    if $apply; then
        args+=(--apply)
    fi
    python3 "$DIR/scripts/airis_bootstrap.py" "${args[@]}"
}

cmd_import() {
    ensure_registry

    local scan_root="$PWD"
    local apply=false
    while [ $# -gt 0 ]; do
        case "$1" in
            --apply) apply=true ;;
            *) scan_root="$1" ;;
        esac
        shift
    done

    python3 - "$REGISTRY_PATH" "$scan_root" "$apply" <<'PY'
import json
import os
import sys
from datetime import datetime, timezone

registry_path, scan_root, apply = sys.argv[1:]
apply = apply.lower() == "true"
scan_root = os.path.abspath(os.path.expanduser(scan_root))
skip_dirs = {
    ".git", ".hg", ".svn", "node_modules", ".venv", "venv",
    "dist", "build", ".next", "target", "__pycache__",
}

with open(registry_path, encoding="utf-8") as f:
    registry = json.load(f)

def canonical(server):
    return {
        "command": server.get("command", ""),
        "args": server.get("args", []),
        "env": server.get("env", {}),
        "enabled": server.get("enabled", True),
    }

def is_gateway_entry(name, server):
    if name == "airis-mcp-gateway":
        return True
    joined = " ".join([server.get("command", "")] + server.get("args", []))
    return "localhost:9400" in joined or "airis-mcp-gateway" in joined

results = []
scan_files = []
for root, dirs, files in os.walk(scan_root):
    dirs[:] = [d for d in dirs if d not in skip_dirs]
    if "mcp.json" in files:
        scan_files.append(os.path.join(root, "mcp.json"))

for source_path in sorted(scan_files):
    repo_path = os.path.dirname(source_path)
    entry = {
        "repo": repo_path,
        "sourcePath": source_path,
        "results": [],
        "status": "imported",
        "lastImportedAt": datetime.now(timezone.utc).isoformat(),
        "backupPath": registry.get("imports", {}).get(repo_path, {}).get("backupPath"),
        "cleanedAt": registry.get("imports", {}).get(repo_path, {}).get("cleanedAt"),
    }
    try:
        with open(source_path, encoding="utf-8") as f:
            payload = json.load(f)
        mcp_servers = payload.get("mcpServers")
        if not isinstance(mcp_servers, dict):
            entry["status"] = "invalid"
            entry["results"].append(("invalid", "mcpServers"))
            results.append(entry)
            continue

        for name, server in mcp_servers.items():
            if not isinstance(server, dict):
                entry["status"] = "invalid"
                entry["results"].append(("invalid", name))
                continue
            if is_gateway_entry(name, server):
                entry["results"].append(("ignored-gateway-entry", name))
                continue

            existing = registry["servers"].get(name)
            normalized = canonical(server)
            if existing is None:
                entry["results"].append(("imported", name))
                if apply:
                    registry["servers"][name] = {
                        **normalized,
                        "source": "imported",
                        "origins": [source_path],
                    }
            else:
                existing_normalized = canonical(existing)
                if existing_normalized == normalized:
                    entry["results"].append(("duplicate", name))
                    if apply:
                        origins = existing.setdefault("origins", [])
                        if source_path not in origins:
                            origins.append(source_path)
                else:
                    entry["status"] = "conflicted"
                    entry["results"].append(("conflicted", name))

        if not entry["results"]:
            entry["status"] = "empty"
    except Exception:
        entry["status"] = "invalid"
        entry["results"].append(("invalid", os.path.basename(source_path)))

    results.append(entry)
    if apply:
        registry["imports"][repo_path] = {
            "sourcePath": source_path,
            "status": entry["status"],
            "servers": {name: status for status, name in entry["results"]},
            "backupPath": entry["backupPath"],
            "lastImportedAt": entry["lastImportedAt"],
            "cleanedAt": entry["cleanedAt"],
        }

if apply:
    with open(registry_path, "w", encoding="utf-8") as f:
        json.dump(registry, f, indent=2)

print(f"Scanned: {scan_root}")
print(f"Found {len(results)} mcp.json file(s)")
print("")

for entry in results:
    rel = os.path.relpath(entry["sourcePath"], scan_root)
    print(rel)
    if not entry["results"]:
        print("  empty: no MCP servers found")
    else:
        for status, name in entry["results"]:
            print(f"  {status}: {name}")
    print("")

if not apply:
    print("Dry run only. No files changed.")
    print("Run again with --apply to write registry.")
PY
}

cmd_clean() {
    ensure_registry

    local scan_root="$PWD"
    local dry_run=false
    while [ $# -gt 0 ]; do
        case "$1" in
            --dry-run) dry_run=true ;;
            *) scan_root="$1" ;;
        esac
        shift
    done

    python3 - "$REGISTRY_PATH" "$BACKUP_DIR" "$scan_root" "$dry_run" <<'PY'
import json
import os
import shutil
import sys
from datetime import datetime, timezone

registry_path, backup_dir, scan_root, dry_run = sys.argv[1:]
dry_run = dry_run.lower() == "true"
scan_root = os.path.abspath(os.path.expanduser(scan_root))

with open(registry_path, encoding="utf-8") as f:
    registry = json.load(f)

backed_up = []
removed = []
skipped = []
timestamp = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")

for repo_path, entry in sorted(registry.get("imports", {}).items()):
    source_path = entry.get("sourcePath")
    if not source_path:
        continue
    if not os.path.abspath(source_path).startswith(scan_root):
        continue
    if not os.path.exists(source_path):
        continue
    if entry.get("status") != "imported":
        skipped.append((source_path, f"status={entry.get('status')}"))
        continue
    if entry.get("cleanedAt"):
        continue

    repo_name = os.path.basename(repo_path.rstrip(os.sep)) or "repo"
    backup_path = os.path.join(backup_dir, f"{repo_name}-{timestamp}-mcp.json")
    if not dry_run:
        shutil.copy2(source_path, backup_path)
        os.remove(source_path)
        entry["backupPath"] = backup_path
        entry["cleanedAt"] = datetime.now(timezone.utc).isoformat()
    backed_up.append(backup_path)
    removed.append(source_path)

if not dry_run:
    with open(registry_path, "w", encoding="utf-8") as f:
        json.dump(registry, f, indent=2)

print("Backed up:")
if backed_up:
    for path in backed_up:
        print(f"  {path}")
else:
    print("  (none)")

print("Removed:")
if removed:
    for path in removed:
        print(f"  {path}")
else:
    print("  (none)")

print("Skipped:")
if skipped:
    for path, reason in skipped:
        print(f"  {path} ({reason})")
else:
    print("  (none)")

if dry_run:
    print("")
    print("Dry run only. No files changed.")
PY
}

cmd_doctor() {
    ensure_bootstrap_support
    local scan_root="${1:-$PWD}"
    python3 "$DIR/scripts/airis_bootstrap.py" doctor \
        --scan-root "$scan_root" \
        --registry-path "$REGISTRY_PATH" \
        --registry-dir "$REGISTRY_DIR" \
        --backup-dir "$BACKUP_DIR" \
        --codex-config-path "$CODEX_CONFIG_PATH" \
        --claude-desktop-config-path "$CLAUDE_DESKTOP_CONFIG_PATH" \
        --claude-code-dir "$CLAUDE_CODE_DIR" \
        --gemini-dir "$GEMINI_CONFIG_DIR" \
        --gateway-http-url "$GATEWAY_HTTP_URL" \
        --gateway-sse-url "$GATEWAY_SSE_URL"
}

cmd_help() {
    cat <<EOF
AIRIS MCP Gateway - Unified MCP server management

Usage: airis-gateway <command> [options]

Commands:
  up [--profile ui]   Start gateway (pulls latest version)
  down                Stop gateway
  restart             Restart gateway
  logs [-f]           View logs
  status              Show docker compose status
  config              Edit mcp-config.json
  init [path]         Plan global bootstrap; use --apply to sync clients and deploy assets
  import [path]       Import repo-local mcp.json into global registry
  clean [path]        Backup and remove imported repo-local mcp.json
  doctor [path]       Detect forbidden repo-local mcp.json, client drift, and missing AIRIS assets

Server Management:
  servers             List MCP servers and their status
  enable <server>     Enable an MCP server
  disable <server>    Disable an MCP server

Configuration:
  Install dir: $DIR
  Registry:    $REGISTRY_PATH

Client policy:
  Codex is managed by AIRIS when available.
  Claude Desktop is detected but never modified automatically.

Environment variables:
  AIRIS_MCP_DIR       Install directory (default: ~/.local/share/airis-mcp-gateway)
  AIRIS_VERSION       Version (default: latest)

Ports:
  9400  API (REST + MCP SSE)
  9390  MCP Gateway
  5273  Settings UI (with --profile ui)

Examples:
  airis-gateway up                    # Start gateway
  airis-gateway up --profile ui       # Start with Settings UI
  airis-gateway servers               # List MCP servers
  airis-gateway enable puppeteer      # Enable puppeteer server
  airis-gateway disable serena        # Disable serena server
  airis-gateway restart               # Apply changes
  airis-gateway init ~/github         # Show bootstrap plan
  airis-gateway init ~/github --apply # Import, clean, and deploy AIRIS assets
  airis-gateway doctor ~/github
EOF
}

case "${1:-help}" in
    up)      shift; cmd_up "$@" ;;
    down)    shift; cmd_down "$@" ;;
    restart) shift; cmd_restart "$@" ;;
    logs)    shift; cmd_logs "$@" ;;
    status)  cmd_status ;;
    config)  cmd_config ;;
    init)    shift; cmd_init "$@" ;;
    import)  shift; cmd_import "$@" ;;
    clean)   shift; cmd_clean "$@" ;;
    doctor)  shift; cmd_doctor "$@" ;;
    servers) cmd_servers ;;
    enable)  shift; cmd_enable "${1:-}" ;;
    disable) shift; cmd_disable "${1:-}" ;;
    --uninstall|-u|uninstall)
        log_warn "Uninstalling AIRIS MCP Gateway..."
        if command -v claude >/dev/null 2>&1; then
            claude mcp remove airis-mcp-gateway --scope user 2>/dev/null || true
        fi
        if [ -f "$DIR/docker-compose.yml" ]; then
            cd "$DIR" && docker compose down -v 2>/dev/null || true
        fi
        [ -d "$DIR" ] && rm -rf "$DIR" && log_info "Removed $DIR"
        [ -f "$HOME/.local/bin/airis-gateway" ] && rm -f "$HOME/.local/bin/airis-gateway" && log_info "Removed CLI"
        log_info "Uninstall complete."
        ;;
    help|--help|-h) cmd_help ;;
    *)
        log_error "Unknown command: $1"
        cmd_help
        exit 1
        ;;
esac
